{
  "name": "example-workspace-aware",
  "description": "Generates personalized greetings with optional workspace persistence for remembering user preferences across sessions",
  "version": "1.0.0",
  "author": "OS Loop",
  "schemaVersion": "2.0",
  "capabilities": ["greeting-with-memory"],
  "requiredBindings": [],
  "permissions": [],
  "inputSchema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Name of the person to greet"
      },
      "style": {
        "type": "string",
        "enum": ["formal", "casual", "enthusiastic", "poetic"],
        "description": "Greeting style override (saved to preferences if workspace is active)"
      },
      "language": {
        "type": "string",
        "description": "Language for the greeting (e.g., 'en', 'es', 'fr'). Saved to preferences if workspace is active."
      }
    },
    "required": ["name"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "greeting": {
        "type": "string",
        "description": "The generated greeting"
      },
      "preferencesUsed": {
        "type": "object",
        "description": "The preferences that were applied"
      },
      "persistent": {
        "type": "boolean",
        "description": "Whether preferences were loaded from / saved to workspace"
      }
    },
    "required": ["greeting", "persistent"]
  },
  "compatibilityRequirements": [],
  "oauth": [],
  "llmUsage": [],
  "wasm": [],
  "views": [],
  "tools": [],
  "lifecycleHooks": [],
  "sandbox": {
    "isolation": "standard",
    "maxExecutionMs": 5000,
    "maxMemoryMB": 32,
    "allowedGlobals": [],
    "networkRules": []
  },
  "supportedPlatforms": [],
  "bridgeRequirement": "never",
  "workspaceSupport": "optional",
  "workspaceSchemaVersion": "1.0.0",
  "longRunningSupport": "none",
  "userInputSupport": false,
  "artifactVersioningSupport": false,
  "executionMode": "declarative",
  "agenticConfig": {
    "enabled": false,
    "requiresWorkspace": false,
    "supportsBackgroundExecution": false,
    "supportsRoleBasedExecution": false,
    "maxStepsPerRun": null,
    "defaultStepBudget": null
  }
}
